rules_version = '2';

// ── EduPlay Firestore Security Rules ──────────────────────────────────────────
//
// Collections & access model:
//
//  parents/{uid}                     — authenticated parent only
//    child_profiles/{profileId}      — parent only
//    subscription/{doc}              — read-only for parent; Cloud Functions write
//
//  teachers/{uid}                    — authenticated teacher only
//    classes/{classId}               — teacher only
//
//  schools/{schoolId}                — admin + member teachers read; admin write
//
//  practice_sessions/{sessionId}     — parent owns; anonymous child updates scores
//
//  leaderboard/{uid}                 — any auth reads; owner writes
//
//  students/{studentId}              — legacy guest/child scores (shape-validated)
//    scores/{scoreId}

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Parents ───────────────────────────────────────────────────────────────
    match /parents/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /child_profiles/{profileId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /subscription/{doc} {
        // Parents can read their subscription status.
        // Only Cloud Functions (Stripe webhook) may write here.
        allow read:  if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // ── Teachers ──────────────────────────────────────────────────────────────
    match /teachers/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /classes/{classId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Schools ───────────────────────────────────────────────────────────────
    match /schools/{schoolId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null && (
        resource.data.adminUid == request.auth.uid ||
        request.auth.uid in resource.data.teacherIds
      );
      allow update, delete: if request.auth != null
        && resource.data.adminUid == request.auth.uid;
    }

    // ── Practice Sessions ─────────────────────────────────────────────────────
    // Children use anonymous Firebase Auth (signed in automatically on the
    // SessionEntryPage). They can read active sessions and update only the
    // score/progress fields — they cannot change parentUid, pin, etc.
    match /practice_sessions/{sessionId} {

      allow read: if request.auth != null && (
        resource.data.isActive == true
        || resource.data.parentUid == request.auth.uid
      );

      allow create: if request.auth != null
        && request.resource.data.parentUid == request.auth.uid;

      allow update: if request.auth != null && (
        // Parent: full control over their session
        resource.data.parentUid == request.auth.uid
        ||
        // Child (anonymous kiosk): may only advance score/progress on active sessions
        (
          resource.data.isActive == true
          && request.resource.data.diff(resource.data)
               .affectedKeys()
               .hasOnly(['completedGameIds', 'scoreMap'])
        )
      );

      allow delete: if request.auth != null
        && resource.data.parentUid == request.auth.uid;
    }

    // ── Leaderboard ───────────────────────────────────────────────────────────
    // Any authenticated user can read the leaderboard.
    // Each user writes only their own entry.
    // (Consider a Cloud Function to prevent score tampering in production.)
    match /leaderboard/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Legacy student scores (guest/child, shape-validated) ──────────────────
    function isValidStudent(data) {
      return data.name is string
        && data.age is int
        && data.points is int
        && data.streak is int;
    }

    function isValidScore(data) {
      return data.subjectKey is string
        && data.gameTitle is string
        && data.score is int
        && data.date is timestamp;
    }

    match /students/{studentId} {
      allow read: if true;
      allow create, update: if isValidStudent(request.resource.data);
      allow delete: if false;

      match /scores/{scoreId} {
        allow read: if true;
        allow create: if isValidScore(request.resource.data);
        allow update, delete: if false;
      }
    }

    // ── Default: deny everything not matched above ────────────────────────────
  }
}
